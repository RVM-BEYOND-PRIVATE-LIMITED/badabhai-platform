{
  "name": "@badabhai/reach-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic Reach Engine RANK core — score + order workers for a job (sort-never-block, hot-tag). Pure, dependency-free; Phase-2 surfaces consume it.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf --glob dist .turbo *.tsbuildinfo"
  }
}
