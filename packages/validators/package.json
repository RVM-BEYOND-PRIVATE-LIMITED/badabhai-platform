{
  "name": "@badabhai/validators",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable Zod validators (phone, uuid, language, voice duration, safe text, consent).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf --glob dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@badabhai/types": "workspace:*",
    "zod": "^3.24.1"
  }
}
