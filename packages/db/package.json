{
  "name": "@badabhai/db",
  "version": "0.1.0",
  "private": true,
  "description": "BadaBhai database package — Drizzle schema, migrations, and client for Supabase Postgres.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "files": ["dist", "migrations"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "db:seed:questionnaire": "tsx src/seed-questionnaire.ts",
    "db:seed:jobs": "tsx src/seed-jobs.ts",
    "db:seed:demand": "tsx src/seed-demand.ts",
    "db:seed:skills": "tsx src/seed-skills.ts",
    "db:embed:skills": "tsx src/embed-skill-aliases.ts",
    "db:verify:demand": "tsx src/verify-demand.ts",
    "db:seed:reach": "tsx src/seed-reach-pool.ts",
    "db:seed:reach:large": "tsx src/seed-reach-pool.ts",
    "db:unseed:reach": "tsx src/seed-reach-pool.ts --unseed-only",
    "db:verify:reach": "tsx src/verify-reach.ts",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@badabhai/reach-engine": "workspace:*",
    "@badabhai/taxonomy": "workspace:*",
    "@badabhai/types": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2"
  }
}
