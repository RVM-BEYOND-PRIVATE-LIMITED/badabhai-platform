# =============================================================================
# BadaBhai Platform — Environment Template
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in real values for LOCAL development only.
# NEVER commit a real .env or real secrets. This file must contain ONLY
# placeholders. Service-role / API keys are backend-only and must NOT be
# exposed to the web or worker-app frontends.
# =============================================================================

# ---- Runtime ----
NODE_ENV=development

# ---- Core datastores ----
# Local docker-compose Postgres (see docker-compose.yml). For Supabase, use the
# connection string from the Supabase dashboard (Project Settings > Database).
DATABASE_URL=postgresql://badabhai:badabhai@localhost:5432/badabhai
REDIS_URL=redis://localhost:6379

# ---- Supabase (BACKEND ONLY) ----
# SUPABASE_URL is safe to expose; the SERVICE_ROLE/SECRET key is a god-key — backend only.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-or-secret-key-backend-only
# Private Storage bucket for the full worker-conversation JSON artifact (ADR-0003).
# Backend/service-role only — never expose to web/worker-app. Object keys are opaque
# UUIDs (worker_id/session_id) only; no PII in the path.
CONVERSATIONS_BUCKET=worker-conversations
# Private Storage bucket for rendered resume PDFs (TD5). MUST be PRIVATE (anon denied):
# provision via infra/supabase/storage-buckets.sql (out-of-band, NOT a Drizzle migration —
# RLS only covers Postgres tables, not Storage object ACLs). Object keys are opaque UUIDs;
# the worker name lives in the PDF bytes, served only via short-TTL backend signed URLs.
RESUMES_BUCKET=worker-resumes
# Private Storage bucket for rendered per-trade interview-kit PDFs (Task 4). PII-FREE
# (per-trade, not per-worker) but still PRIVATE — provisioned by the same
# infra/supabase/storage-buckets.sql. Served only via short-TTL backend signed URLs.
INTERVIEW_KIT_BUCKET=interview-kits

# ---- Resume / interview-kit render worker (TD5/TD24, BACKEND ONLY) ----
# Master switch for the WeasyPrint render step (governs BOTH resume + interview-kit
# rendering — the requested WEASYPRINT_ENABLED maps onto this). Off by default so the
# API runs without the binary in local dev (renderer degrades to "no PDF this run").
# Set to true in staging/prod once the binary is present (the API Dockerfile installs it).
RESUME_RENDER_ENABLED=false
# Per-worker generations allowed per UTC day; global cap is the interim backstop
# until TD4 binds a request to an authenticated worker.
RESUME_DAILY_CAP=5
RESUME_GLOBAL_DAILY_CAP=5000
# Per-IP DOWNLOAD caps per rolling UTC hour (TD24 abuse backstop). The IP is
# HMAC-hashed before any Redis key/log. Fail-closed if Redis is down.
RESUME_RATE_LIMIT_PER_IP_PER_HOUR=20
INTERVIEW_KIT_RATE_LIMIT_PER_IP_PER_HOUR=20
# Interview-kit content version — part of the render-once identity. BUMP whenever any
# kit copy (interview-kit-content.ts) changes so a fresh PDF renders instead of the cache.
INTERVIEW_KIT_CONTENT_VERSION=1
# Internal service secret (NOT user auth) gating the ops/backend-only resume routes
# (GET /resume/:id, /:id/download, /:id/share, /:id/regenerate). UNSET => those routes
# deny ALL callers (fail closed). Uncomment + set a strong random value to use them
# (ops/internal callers send it as the x-internal-service-token header). Real per-worker
# auth is TD4. Treat as a secret.
# INTERNAL_SERVICE_TOKEN=replace-with-a-strong-random-secret
# TTL (seconds) for a freshly minted signed resume-download URL (15 min default).
RESUME_SIGNED_URL_TTL_SECONDS=900

# ---- PII protection (BACKEND ONLY) ----
# Pepper for the keyed HMAC of phone/IP (so hashes aren't brute-forceable), and an
# AES-256-GCM key (base64 of 32 bytes) for encrypting phone_e164 at rest. The key
# NEVER touches the database. REQUIRED in production — the API refuses to boot with
# the dev defaults when NODE_ENV=production. Generate fresh values with:
#   node -e "const c=require('crypto');console.log('PII_HASH_PEPPER='+c.randomBytes(32).toString('hex'));console.log('PII_ENCRYPTION_KEY='+c.randomBytes(32).toString('base64'))"
PII_HASH_PEPPER=replace-with-32+-byte-random-pepper
PII_ENCRYPTION_KEY=replace-with-base64-of-32-random-bytes

# ---- Worker auth: OTP login + rolling session (BACKEND ONLY) ----
# Secret that signs the worker session JWT. REQUIRED in production — the API
# refuses to boot with the dev default when NODE_ENV is not development/test.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-32+-byte-random
# Session lifetime in days (token + Redis session share this TTL; rolling/sliding).
SESSION_TTL_DAYS=30
# OTP shape + lifecycle. The code is generated with crypto.randomInt per digit,
# stored in Redis ONLY as a keyed HMAC, single-use, and rate-limited per phone + IP.
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_SENDS_PER_HOUR=5
# GLOBAL daily send circuit-breaker for the WORKER SMS path (OTP-5 — the SPEND ceiling).
# Bounds the TOTAL number of REAL Fast2SMS sends platform-wide per UTC day, above the
# per-phone + per-IP caps, so a distributed abuser cannot run up the bill. The SMS path is
# REAL-ONLY (Fast2SMS — no console fallback), so this ALWAYS enforces. Set to 0 to instantly
# PAUSE real sends (the worker-SMS KILL-SWITCH) — env-only, NO redeploy; the next send is
# blocked + a PII-free breach event fires. NEVER a secret.
OTP_GLOBAL_MAX_SENDS_PER_DAY=2000
# SMS delivery is REAL-ONLY: "fast2sms" is the only provider — there is NO console/mock
# option. The API REFUSES TO BOOT (fails closed) without the FAST2SMS_* credentials below
# in EVERY environment (assertAuthConfig). The literal keeps the env var for back-compat.
SMS_PROVIDER=fast2sms
# Fast2SMS (DLT route) — REQUIRED AT BOOT (the app fails closed without them). These are
# BACKEND-ONLY secrets; supply the real credentials + approved DLT template/variable order
# in staging-first. Placeholders only here — NEVER commit a real API key.
FAST2SMS_API_KEY=replace-with-real-fast2sms-api-key
FAST2SMS_SENDER_ID=BADBHI
FAST2SMS_DLT_TEMPLATE_ID=replace-with-real-dlt-template-id
FAST2SMS_ENTITY_ID=
FAST2SMS_ROUTE=dlt

# ---- Payer email OTP (real provider — ADR-0019; human-gated, staging-first) ----
# These gate the REAL payer email-OTP channel and are RELEVANT ONLY when
# PAYER_LOGIN_METHOD=email_otp (the default). The channel is REAL-ONLY: there is NO "none"/
# mock option — a real provider's credentials are REQUIRED AT BOOT (assertPayerAuthConfig
# fails closed without them, never silently degrading). EMAIL_PROVIDER selects the transport:
# "zeptomail" (default), "smtp", or "auto". Supplying the real keys is human-gated +
# staging-first (CLAUDE.md §7). All keys are BACKEND-ONLY secrets — never NEXT_PUBLIC_*.
# Placeholders only here — NEVER commit a real ZeptoMail token (it is a long opaque string).
EMAIL_PROVIDER=zeptomail
# ZeptoMail (HTTPS send API). API_URL is a non-secret endpoint default; TOKEN + MAIL_AGENT
# are secrets REQUIRED when EMAIL_PROVIDER=zeptomail (or auto). Requires EMAIL_FROM_ADDRESS.
ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email
ZEPTOMAIL_API_TOKEN=replace-with-real-zeptomail-token
ZEPTOMAIL_MAIL_AGENT=replace-with-real-mail-agent
ZEPTOMAIL_SANDBOX_MODE=false
# Generic SMTP relay (alternative to ZeptoMail). Required when EMAIL_PROVIDER=smtp (or auto
# without ZeptoMail creds). Requires EMAIL_FROM_ADDRESS below when used.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Shared From identity for the rendered email (both providers). EMAIL_FROM_ADDRESS is a
# required cred for every REAL provider; NAME + REPLY_TO are presentation-only.
EMAIL_FROM_NAME=BadaBhai
EMAIL_FROM_ADDRESS=otp@example.com
EMAIL_REPLY_TO=
# GLOBAL daily send circuit-breaker for the PAYER EMAIL-OTP path (OTP-5 — the SPEND
# ceiling; payer analogue of OTP_GLOBAL_MAX_SENDS_PER_DAY). Bounds the TOTAL number of
# REAL payer email sends platform-wide per UTC day. The email channel is REAL-ONLY
# (zeptomail/smtp), so this ALWAYS enforces. On breach the response stays byte-identical
# for a known vs unknown account (no enumeration oracle). Set to 0 to instantly PAUSE real
# sends (the payer-email KILL-SWITCH) — env-only, NO redeploy; the next send is blocked +
# a PII-free breach event fires. NEVER a secret.
PAYER_OTP_GLOBAL_MAX_SENDS_PER_DAY=2000

# Payer org teammate INVITES — real accept-link email (ADR-0027 / B5.4). The invite ACCEPT
# flow (single-use token verify → member activation) is ALWAYS live; only the outbound
# real-email DELIVERY is gated. MEMBER_INVITES_ENABLE_REAL defaults FALSE: the MOCK mailer
# (no send — the raw token / accept link never leaves the process) is the alpha default.
# Flipping it true reuses the REAL email provider above (EMAIL_PROVIDER + its creds) AND
# requires MEMBER_INVITE_ACCEPT_URL; it is human-gated + staging-first (CLAUDE.md §7). A
# real-enabled flag missing the email creds / accept URL fails CLOSED at boot. NEVER a secret.
MEMBER_INVITES_ENABLE_REAL=false
# Base URL of the payer-web invite-accept page. The single-use raw token is appended as
# `?token=…` to build the accept link that goes ONLY into the invite email body (never
# logged/evented). REQUIRED when MEMBER_INVITES_ENABLE_REAL=true; unused by the mock mailer.
MEMBER_INVITE_ACCEPT_URL=
# Per-org cap on concurrently non-removed members (active + invited) — a backstop against
# unbounded invite minting. Reaching it rejects further invites (409) until a seat frees up.
MEMBER_INVITE_MAX_PER_ORG=25

# ---- AI routing (direct Gemini, no LiteLLM) ----
# The AI service calls Google AI Studio (Gemini) DIRECTLY over REST with httpx —
# there is NO LiteLLM proxy. This key is backend/staging-only (never NEXT_PUBLIC_*,
# never the web/worker app). Placeholder only — set a real key in staging env.
GEMINI_FLASH_API_KEY=replace-with-google-ai-studio-key
# Master kill-switch for real LLM calls. MUST stay false unless intentionally
# enabling real model traffic. Pseudonymization always runs first regardless.
AI_ENABLE_REAL_CALLS=false
# Per-task allowlist for real calls (comma-separated). Lets ONE role/task go real
# while the rest stay mock — e.g. enable only canonicalization first. EMPTY = all
# tasks (when the master flag is on). Requires the master flag + GEMINI_FLASH_API_KEY.
# Tasks: profiling_chat_turn, profile_extraction, resume_generation.
# Staging rollout: AI_REAL_CALL_TASKS=profile_extraction  (see docs/ai/enable-real-llm-extraction.md)
AI_REAL_CALL_TASKS=

# WhatsApp invite funnel + re-engagement (ADR-0020). MOCK provider by default — no
# real message is sent and a worker's phone never leaves to Meta. Flipping
# MESSAGING_ENABLE_REAL=true requires the WhatsApp keys AND is human-gated +
# staging-first (CLAUDE.md §7); a real-enabled flag without keys fails closed at boot.
# Also requires the worker's `whatsapp_messaging` DPDP consent (fail-closed).
MESSAGING_ENABLE_REAL=false
# Meta WhatsApp Cloud API credentials — leave blank in dev/alpha (mock provider).
# Supplied only in staging-first behind MESSAGING_ENABLE_REAL. NEVER commit real values.
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# ---- Model routing + cost guardrails ----
# Bare Gemini model ids (no provider prefix). The capable tier handles extraction.
DEFAULT_CHEAP_MODEL=gemini-2.5-flash-lite
DEFAULT_CAPABLE_MODEL=gemini-2.5-flash
# Per-profile cost guardrails (INR). Alert/target are flags only; the ceiling is
# a hard per-call cap — a real call whose worst-case cost exceeds it falls back to mock.
AI_COST_ALERT_PROFILE_INR=6
AI_TARGET_PROFILE_COST_INR=4
AI_MAX_CALL_COST_INR=10

# ---- Fallback provider: Anthropic / Claude (BACKEND ONLY) ----
# OPTIONAL. When set, Claude Haiku is added to the router's provider-fallback
# chain (Gemini primary -> Claude Haiku -> deterministic mock), used only when a
# real Gemini call fails. This key is NOT a master gate — GEMINI_FLASH_API_KEY +
# AI_ENABLE_REAL_CALLS still govern whether real calls happen at all. Placeholder
# only; treat as a secret. Reached via the official `anthropic` SDK.
ANTHROPIC_API_KEY=
# Fallback model id (no date suffix, per the Anthropic API).
DEFAULT_FALLBACK_MODEL=claude-haiku-4-5

# ---- Google Cloud (optional; Node-side declarations only) ----
# NOTE: the AI service no longer reads these — it calls Gemini directly via
# GEMINI_FLASH_API_KEY above. These remain only because packages/config/src/server.ts
# still declares them (all optional). Safe to leave blank.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GEMINI_API_KEY=

# ---- Speech-to-text (Sarvam) ----
# Real STT requires AI_ENABLE_REAL_CALLS=true AND SARVAM_API_KEY (fails closed to
# an empty transcript otherwise — never fabricated). The AI service ALSO reads the
# SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY above to fetch the uploaded voice audio
# (Storage Mode A, service-role) before transcribing. The Sarvam sync endpoint
# accepts clips UNDER 30s only; longer audio fails closed (batch STT is future work).
SARVAM_API_KEY=replace-with-sarvam-key
# Private bucket holding uploaded voice notes (object key = the request storage_path).
# MUST be created PRIVATE out-of-band — Storage object ACLs are not covered by RLS.
VOICE_NOTES_BUCKET=worker-voice-notes
# Sarvam STT model id (config so the future saaras:v3 swap is one line).
SARVAM_STT_MODEL=saarika:v2.5
# Sarvam text-translation model — English output via /translate (mayura:v1 is the
# only model with auto-detect + code-mixed/Hinglish source support).
SARVAM_TRANSLATE_MODEL=mayura:v1

# ---- Observability (Langfuse placeholders) ----
LANGFUSE_PUBLIC_KEY=replace-with-langfuse-public-key
LANGFUSE_SECRET_KEY=replace-with-langfuse-secret-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ---- Service URLs / ports ----
API_PORT=3001
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000
WEB_PORT=3000

# ---- Web (Next.js) PUBLIC config (NEXT_PUBLIC_* is shipped to the browser) ----
# Only non-secret values belong here.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ENVIRONMENT=development
# Supabase client (browser-safe) — the publishable/anon key, NOT the secret key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me
# Web (Next.js) SERVER-only secret (NOT NEXT_PUBLIC_*, never shipped to the browser):
# the ops console's applicants pages (ADR-0009) read API routes behind
# InternalServiceGuard, so the console process needs the SAME INTERNAL_SERVICE_TOKEN
# set above (line ~59) in its server environment. It is read only in Server Components
# (apps/web/src/lib/api.ts via process.env) — it is never inlined into the client
# bundle. Unset => those reads get 401 and the page shows its error state.
