# =============================================================================
# STAGING-ONLY resume-render enablement for the NestJS API (TD24 / ADR-0007).
# Template — NO SECRETS. Copy into the STAGING environment's secrets (or a staging
# `.env` that is NEVER committed) and fill the <...> placeholders.
#
# DO NOT use on a dev laptop, in CI, or against production. The repo default stays
# OFF: .env.example keeps RESUME_RENDER_ENABLED=false, and the code default is
# false (packages/config booleanFromString). Full runbook + verify + rollback:
#   infra/supabase/storage-buckets.md
#
# GATE (do these BEFORE flipping the switch):
#   1. worker-resumes bucket provisioned PRIVATE (infra/supabase/storage-buckets.sql)
#      and verified public=false + public route 400/403.
#   2. WeasyPrint present in the API image (apps/api/Dockerfile) — else renders no PDF.
# =============================================================================

# --- Supabase Storage (service-role = god-key; backend only, NEVER client) -----
SUPABASE_URL=https://<staging-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<staging service-role / secret key>
RESUMES_BUCKET=worker-resumes
INTERVIEW_KIT_BUCKET=interview-kits

# --- the flip ----------------------------------------------------------------
# Master kill-switch for the WeasyPrint render step (resume + interview-kit).
RESUME_RENDER_ENABLED=true
# Short TTL for a freshly minted signed download URL (seconds). 15 min default;
# tighten if desired. Resumes are served ONLY via these signed URLs — never a
# public object URL.
RESUME_SIGNED_URL_TTL_SECONDS=900

# --- abuse backstops (TD24) --------------------------------------------------
RESUME_DAILY_CAP=5                       # per-worker generations / UTC day
RESUME_GLOBAL_DAILY_CAP=5000             # global spend backstop until TD4
RESUME_RATE_LIMIT_PER_IP_PER_HOUR=20     # per-IP download cap / rolling hour

# --- internal service auth (NOT user auth) -----------------------------------
# Gates the ops/backend-only resume routes (GET /resume/:id, /:id/download, …).
# UNSET => those routes deny ALL callers (fail closed). Treat as a secret.
INTERNAL_SERVICE_TOKEN=<strong-random-secret>

# --- payments (ADR-0013 / ADR-0010) — MOCK by default; Razorpay is HUMAN-GATED ---
# ALL monetization (job-posting plans, boosters, contact-unlock packs) is MOCK in
# alpha: PAYMENTS_ENABLE_REAL is the master gate and DEFAULTS FALSE (code default +
# .env). Leave it false. Flipping it true requires the real provider key AND is a
# human-gated, staging-first escalation (CLAUDE.md §7); a real-enabled flag WITHOUT
# the key fails CLOSED at boot (assertPaymentsConfig). DO NOT enable here without
# explicit sign-off.
PAYMENTS_ENABLE_REAL=false
# Opaque RAZORPAY key — the chosen real provider. NEVER committed; supplied only in
# staging once real payments are signed off. Unused while PAYMENTS_ENABLE_REAL=false.
PAYMENTS_PROVIDER_KEY=<razorpay-key-id:key-secret — staging only, when enabled>
