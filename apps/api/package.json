{
  "name": "@badabhai/api",
  "version": "0.1.0",
  "private": true,
  "description": "BadaBhai NestJS backend — Phase 1 worker profiling API (event-first).",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@badabhai/ai-contracts": "workspace:*",
    "@badabhai/config": "workspace:*",
    "@badabhai/db": "workspace:*",
    "@badabhai/event-schema": "workspace:*",
    "@badabhai/pricing": "workspace:*",
    "@badabhai/reach-engine": "workspace:*",
    "@badabhai/taxonomy": "workspace:*",
    "@badabhai/types": "workspace:*",
    "@badabhai/validators": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "bullmq": "^5.78.0",
    "drizzle-orm": "^0.38.3",
    "nodemailer": "^9.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/nodemailer": "^8.0.1"
  }
}
