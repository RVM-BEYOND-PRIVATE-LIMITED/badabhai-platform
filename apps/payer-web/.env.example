# @badabhai/payer-web — external payer portal (ADR-0019 Phase 1: MOCK + staging-only).
# Copy to .env.local for local dev. NEVER commit a real secret.

# --- Public (shipped to the browser; NEXT_PUBLIC_* only) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
# Environment label. Set to "staging" (or "production") to mark the session cookie
# `Secure` (HTTPS-only) on a deployed https host. Local http dev stays non-secure so
# the cookie still works. (NEXT_PUBLIC_SITE_URL / VERCEL_URL being https also trips it.)
NEXT_PUBLIC_ENVIRONMENT=development

# --- Agency portal public feature flags (NEXT_PUBLIC_* booleans; no secrets) ---
# DEMAND shell (agency dashboard). Default ON. Off → the agency routes notFound().
NEXT_PUBLIC_ENABLE_AGENCY_PORTAL=true
# Everything below is PARKED / DEAD / DEFERRED — default OFF, and there is NO code path
# that builds the flow. Flipping one ON only re-labels the parked card; it ships nothing.
# SUPPLY (referral funnel) — Phase-2, CEO-gated.
NEXT_PUBLIC_ENABLE_AGENCY_SUPPLY=false
# KYC — HIGH-sensitivity PII; legal/DPDP sign-off required (CEO/legal gate).
NEXT_PUBLIC_ENABLE_AGENCY_KYC=false
# Payouts — real money out; TD34 real payments + product-ratified params required.
NEXT_PUBLIC_ENABLE_AGENCY_PAYOUTS=false
# Bulk raw-phone/CSV invite upload — DEAD (consent violation); never built.
NEXT_PUBLIC_ENABLE_AGENCY_BULK_UPLOAD=false
# Matching / hire-outcome tracking — deferred by product lock.
NEXT_PUBLIC_ENABLE_AGENCY_OUTCOME_TRACKING=false

# --- Server-only (never reaches the client bundle) ---
# Phase 1 LIVE login = "api" (the backend payer-auth OTP routes, R16/LC-1).
# "mock" is the local/test fallback. A third-party IdP/MFA is B-R1 (human gate).
PAYER_AUTH_MODE=api
PAYER_API_URL=http://localhost:3001
# HMAC key for the mock session cookie (only used when PAYER_AUTH_MODE=mock).
PAYER_SESSION_SECRET=change-me-in-staging
# MUST be false. The portal ships MOCK-only and refuses to boot if this is true.
PAYMENTS_ENABLE_REAL=false
# Free-through-launch posting flag (the catalog cannot model a ₹0 price).
PAYER_POSTING_FREE_THROUGH_LAUNCH=true
# Agency SUPPLY (referrals/payouts/KYC) — fail-closed, default false. Phase-2 CEO-gated.
# Only "true" enables the parked LABEL; there is NO referral/payout/KYC code behind it.
AGENCY_SUPPLY_ENABLED=false
