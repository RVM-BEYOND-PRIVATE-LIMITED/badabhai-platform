# @badabhai/payer-web — public (browser-safe) config ONLY.
# NEVER put a server secret here: this app ships everything to the browser and
# only ever holds the authenticated payer's own Bearer session token.

# API origin the SPA calls (payer-auth + own-data endpoints).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Footer label only (development | test | staging | production).
NEXT_PUBLIC_ENVIRONMENT=development
