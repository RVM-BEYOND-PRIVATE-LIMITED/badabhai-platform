<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Firebase Cloud Messaging (native): network + show notifications on Android 13+. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- #377: Android defaults allowBackup to TRUE, which auto-backs the app's data
         up to the payer's Google Drive. Two reasons that is wrong here:

         1. It ships the persisted bearer token into a cloud backup at all — which
            PayerTokenStore's secure-storage posture exists to prevent.
         2. flutter_secure_storage runs on EncryptedSharedPreferences, whose
            documented failure mode is precisely this: restore the prefs XML onto a
            NEW device and the Keystore master key does NOT come with it, so every
            later read throws (BadPadding / keystore error).

         main() awaits PayerTokenStore.load() BEFORE the first frame, so a restored
         payer was stuck on the native splash with no way out but clearing app data.
         load() now also degrades a throwing store to "no session" — defense in
         depth, because a backup can still be restored from an older install made
         while this flag was still on. -->
    <application
        android:label="payer_app"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:fullBackupContent="false">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Disable Impeller: its Vulkan backend renders corrupted output (blue
             diagonal streaks) on some Android emulators/GPU drivers. Falls back to
             the Skia (OpenGL) renderer. Flutter defaults Impeller ON for Android
             since 3.27; re-evaluate when emulator Vulkan drivers stabilise. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />

        <!-- Firebase Cloud Messaging: receives console test pushes; shows foreground
             notifications. Background/killed notification-messages are shown by the OS. -->
        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>
        <!-- Channel id used for background/system-tray FCM notifications (created in FirebaseManager). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="@string/default_notification_channel_id" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- #354 — lets url_launcher resolve a BROWSER for the signed masked-résumé
             url under the Android 11+ (API 30+) package-visibility rules. Without
             this query canLaunchUrl/launchUrl see no handler and the launch fails,
             which would push us straight back to the clipboard fallback this issue
             exists to remove. Scheme-only (no host): the signed url's host is
             environment-dependent, and a host filter would silently break staging.

             NOTE this deliberately differs from the worker app's queries block,
             which declares VIEW application/pdf instead: the worker app fetches
             its signed pdf IN-APP and only opens the resulting LOCAL file, so it
             never launches an https intent. The payer side hands the url to the
             browser, so https is the intent it must be able to see. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
</manifest>
