<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- DEBUG-ONLY: allow cleartext (http://) so the app can reach a LAN dev API
         such as http://<laptop-ip>:3001 or the emulator's http://10.0.2.2:3001.
         This overlay applies only to debug builds (flutter run); release builds
         inherit the main manifest and keep cleartext DISABLED. -->
    <application android:usesCleartextTraffic="true" />
</manifest>
