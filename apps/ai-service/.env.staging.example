# =============================================================================
# STAGING-ONLY real-LLM enablement for the AI service (profile_extraction).
# Template — NO SECRETS. Copy into the STAGING environment's secrets (or a staging
# `.env` that is NEVER committed) and fill the <...> placeholders.
#
# DO NOT use on a dev laptop, in CI, or against production worker data. The repo
# default stays mock: .env.example keeps AI_ENABLE_REAL_CALLS=false and
# AI_REAL_CALL_TASKS= (empty). Full runbook + verification + rollback:
#   docs/ai/enable-real-llm-extraction.md
#
# Gate (config.py): a real call needs the master flag AND the Gemini key
# (GEMINI_FLASH_API_KEY); then — if the allowlist is set — the task must be in it.
# Fail-closed. The Anthropic key only ADDS the Claude Haiku fallback candidate.
# =============================================================================

# --- the flip ---------------------------------------------------------------
AI_ENABLE_REAL_CALLS=true
AI_REAL_CALL_TASKS=profile_extraction        # ONLY canonicalization goes real; chat/resume stay mock

# --- Primary provider: Google AI Studio (Gemini), called DIRECTLY over REST ---
# (httpx — NO litellm, NO openai SDK). GEMINI_FLASH_API_KEY is the master gate
# for real calls. Secret — never commit.
GEMINI_FLASH_API_KEY=<your Gemini API key>
# Extraction tier (bare model id). NOTE: gemini-2.0-flash has free-tier quota = 0
# (429 RESOURCE_EXHAUSTED) and the free 2.5 tier caps at ~20 req/day — the full
# ~50-call eval needs PAID billing (or --min-interval/--per-tier to fit a free cap).
DEFAULT_CAPABLE_MODEL=gemini-2.5-flash

# --- Fallback provider: Anthropic (Claude Haiku) — OPTIONAL ------------------
# Reached via the official `anthropic` SDK. Its presence only adds a fallback
# candidate after a Gemini failure; it can NOT enable real calls on its own.
ANTHROPIC_API_KEY=<anthropic key, optional>
DEFAULT_FALLBACK_MODEL=claude-haiku-4-5

# --- cost guardrails (INR) ---------------------------------------------------
# Per-call worst-case ceiling (a single call over this → refused → mock).
AI_TARGET_PROFILE_COST_INR=4
AI_COST_ALERT_PROFILE_INR=6
AI_MAX_CALL_COST_INR=10
# TD27 cumulative spend cap + retry budget (enforced in AIRouter.run BEFORE the
# provider call, fail-closed → mock; observable via GET /ai/spend + the
# ai.spend_cap_exceeded event). NOTE: per-process (per Uvicorn worker) in Phase 1
# — size with worker count in mind until the shared-store follow-up lands.
AI_MAX_DAILY_COST_INR=200        # process-wide rolling per-UTC-day spend cap (backstop)
AI_MAX_TOTAL_COST_INR=1000       # process-lifetime cumulative spend cap (backstop)
# PER-USER daily budget (INR) — bounds ALL real AI spend for one worker/day
# (profiling chat + extraction + resume combined), keyed by the opaque worker_ref.
# This is the primary user-facing cap; the two above are the no-worker_ref backstop.
AI_MAX_USER_DAILY_COST_INR=6
AI_RETRY_BUDGET_PER_WINDOW=20    # max retries across all requests per window
AI_RETRY_BUDGET_WINDOW_SECONDS=60
# Independent hard kill-switch: set true to instantly disable ALL real calls,
# regardless of AI_ENABLE_REAL_CALLS. Default off.
AI_REAL_CALLS_KILL_SWITCH=false

# --- observability (cost/profile in Langfuse, over PSEUDONYMIZED text only) ---
LANGFUSE_PUBLIC_KEY=<...>
LANGFUSE_SECRET_KEY=<...>

# --- per-field pytest gate target (only the staging pytest reads this; the CLI
#     uses --base-url). Unset => the real ≥90% test is SKIPPED, never failed. ---
AI_EVAL_BASE_URL=http://localhost:8000
