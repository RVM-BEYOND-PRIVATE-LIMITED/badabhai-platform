{
  "name": "badabhai-platform",
  "version": "0.1.0",
  "private": true,
  "description": "BadaBhai — AI placement-team platform for blue/grey-collar India (Phase 1: Worker Profiling).",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:oxlint": "oxlint --config apps/payer-web/.oxlintrc.json apps/payer-web/src",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @badabhai/db db:generate",
    "db:migrate": "pnpm --filter @badabhai/db db:migrate",
    "db:seed:demand": "pnpm --filter @badabhai/db db:seed:demand",
    "db:verify:demand": "pnpm --filter @badabhai/db db:verify:demand",
    "db:seed:skills": "pnpm --filter @badabhai/db db:seed:skills",
    "db:embed:skills": "pnpm --filter @badabhai/db db:embed:skills",
    "db:growth:cluster": "pnpm --filter @badabhai/db db:growth:cluster",
    "db:retag:skills": "pnpm --filter @badabhai/db db:retag:skills",
    "db:seed:reach": "pnpm --filter @badabhai/db db:seed:reach",
    "db:seed:reach:large": "pnpm --filter @badabhai/db db:seed:reach:large",
    "db:unseed:reach": "pnpm --filter @badabhai/db db:unseed:reach",
    "db:verify:reach": "pnpm --filter @badabhai/db db:verify:reach",
    "db:studio": "pnpm --filter @badabhai/db db:studio",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "staging:smoke": "node scripts/staging-smoke.mjs",
    "staging:smoke:test": "node --test scripts/staging-smoke.test.mjs",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "oxlint": "^1.71.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "supabase": "^2.105.0",
    "turbo": "^2.3.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  }
}
